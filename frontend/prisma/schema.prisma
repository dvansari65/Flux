generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Intent {
  id               String       @id @default(cuid())
  maker            String
  recipient        String
  sourceChain      String
  destinationChain String
  inputToken       String
  outputToken      String
  inputAmount      String
  minOutputAmount  String
  nonce            String
  deadline         String
  signature        String
  status           IntentStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

enum IntentStatus {
  PENDING
  AUCTIONING
  FULFILLED
  SETTLED
  CANCELLED
}
